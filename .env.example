# 高德 Web 服务 API（后端 POI 搜索 + 驾车路径规划）— 必填
AMAP_API_KEY=

# 高德 Web 端 JS API（前端地图渲染）— 必填
AMAP_JS_KEY=
AMAP_JS_SECURITY_CODE=

# LLM API（DeepSeek / OpenAI）— 必填
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 数据库连接（Docker 容器内通信，无需修改）
DATABASE_URL=postgresql+asyncpg://travelpal:travelpal123@postgres:5432/travelpal
