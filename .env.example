# 高德 Web 服务 API（后端，POI 搜索 / 驾车路径规划）
AMAP_API_KEY=your_amap_api_key_here

# 高德 Web 端 JS API（前端，地图渲染）
AMAP_JS_KEY=your_amap_js_key_here
AMAP_JS_SECURITY_CODE=your_amap_js_security_code_here

# Cesium Ion Token（3D 地球）
CESIUM_TOKEN=your_cesium_token_here

# LLM API（DeepSeek / OpenAI）
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Embedding API
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=

# 开发模式：后端热重载（true 启用，留空或 false 关闭）
DEV_RELOAD=true
